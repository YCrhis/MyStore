@model List<CartItemVM>

@if (Model.Count() != 0)
{
    <div class="row justify-content-between mt-4">
        <div class="col-4">
            <h4>Cart Items</h4>
        </div>
        <div class="col-4 text-end">
            <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#exampleModal">
                Order Now
            </button>
        </div>
    </div>
    <hr />

    <table class="table">
        <thead class="thead-dark">
            <tr>
                <th scope="col">#</th>
                <th style="width:120px;">Image</th>
                <th scope="col">Name</th>
                <th scope="col">Price</th>
                <th scope="col">Quantity</th>
                <th scope="col">Total</th>
                <th style="width:120px;"></th>
            </tr>
        </thead>
        <tbody>
            @{
                int index = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row">@index</th>
                    <th style="width:120px;">
                        <img class="card-img-top rounded" src="~/images/@item.ImageName" alt="@item.Name" loading="lazy" style="width:100px" />
                    </th>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C2")</td>
                    <td>@item.Quantity</td>
                    <td>@((item.Price * @item.Quantity).ToString("C2"))</td>
                    <td style="width:220px">
                        <a href="/Home/RemoveItemCart?id=@item.ProductId" class="btn btn-danger"><i class="fa-solid fa-trash-can"></i></a>
                    </td>
                </tr>
                index++;
            }
        </tbody>
    </table>

}
else
{
    
    @if (ViewBag.message != null)
    {
        <div class="alert alert-warning mt-4" role="alert">
            There are not products in the cart.
        </div>
    }
}


<div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <form action="/Home/PayNow" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Payment Form</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                
                    <div class="row g-3">
                        <div class="col-12">
                            <input type="email" class="form-control" placeholder="Email" />
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control" placeholder="Adreess" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" placeholder="Country" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" placeholder="City" />
                        </div>
                        <hr />
                        <div class="col-12">
                            <input type="text" class="form-control" placeholder="Cardholder name" />
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control" placeholder="Card number" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" placeholder="MM" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" placeholder="YY" />
                        </div>
                        <div class="col-6">
                            <input type="number" class="form-control" placeholder="CVV" />
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Pay Now</button>
                </div>
            </form>
        </div>
    </div>
</div>

